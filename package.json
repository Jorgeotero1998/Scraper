{
  "name": "jurisprudencia-scraper",
  "version": "2.0.0",
  "description": "Scraper for Peruvian legal jurisprudence databases (OEFA & Poder Judicial)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start:oefa": "ts-node src/index.ts --site=oefa",
    "start:pj": "ts-node src/index.ts --site=pj",
    "build": "tsc --noEmit && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "playwright": "^1.61.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
